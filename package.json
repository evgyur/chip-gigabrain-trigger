{
  "name": "chip-gigabrain-trigger",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Trigger.dev integration module for Gigabrain Task Capsule",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
